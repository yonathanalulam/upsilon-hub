---
import newsData from '../data/news.json';
const allCategories = newsData.map((item: any) => item.category);
const uniqueCategories = [...new Set(allCategories)].sort();
interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Upsilon Hub is an automated intelligence platform tracking the latest breakthroughs in Astrophysics, Quantum Physics, High Energy, and Nanotech." 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/atom.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title.includes('|') ? title : `${title}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    
    <meta property="og:site_name" content="Upsilon Hub" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content="Upsilon Hub - The Frontier of Physics" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://upsilon-hub.vercel.app/social-image.jpg" />

    <meta name="google-site-verification" content="GtX_w4WkaPm6ZJsz755t1qsyC2QRrCSzJJ881KrVch8" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Upsilon Hub",
        "alternateName": ["UpsilonHub", "The Frontier of Physics"],
        "url": "https://upsilon-hub.vercel.app/",
        "publisher": {
          "@type": "Organization",
          "name": "Upsilon Hub",
          "logo": {
            "@type": "ImageObject",
            "url": "https://upsilon-hub.vercel.app/atom.png"
          }
        }
      }
    </script>
    
    <script is:inline>
      if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    
    <style is:global>
      :root { font-family: 'system-ui', sans-serif; }
      
      /* --- GLOBAL BUTTERY ANIMATION --- */
      @keyframes fadeInUp {
        0% {
          opacity: 0;
          transform: translateY(10px); 
        }
        100% {
          opacity: 1;
          transform: translateY(0); 
        }
      }

      .animate-card-entry {
        animation: fadeInUp 0.5s ease-out forwards;
        opacity: 0; 
      }

      /* Preloader */
      #preloader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        background-color: #121212; 
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.76, 0, 0.24, 1);
      }
      html:not(.dark) #preloader { background-color: #fff5d7; }

      .preloader-hidden {
        opacity: 0;
        transform: scale(1.02);
        pointer-events: none;
      }

      .atom-container {
        position: relative;
        width: 120px;
        height: 120px;
        display: flex;
        justify-content: center;
        align-items: center;
        perspective: 1000px;
      }

      .nucleus {
        position: absolute;
        width: 16px;
        height: 16px;
        background: #ff5e6c;
        border-radius: 50%;
        box-shadow: 0 0 25px #ff5e6c;
        z-index: 10;
        animation: pulseNucleus 3s infinite ease-in-out;
      }
      html:not(.dark) .nucleus {
        background: #ff5e6c;
        box-shadow: 0 0 25px #ff5e6c;
      }

      .orbit {
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 2px solid rgba(255, 94, 108, 0.2);
        transform-style: preserve-3d;
      }
      html:not(.dark) .orbit {
        border-color: rgba(255, 94, 108, 0.2);
      }
      
      .orbit::before {
        content: '';
        position: absolute;
        top: -5px;
        left: 50%;
        transform: translateX(-50%);
        width: 8px;
        height: 8px;
        background: white;
        border-radius: 50%;
        box-shadow: 0 0 10px white;
      }
      html:not(.dark) .orbit::before { background: #ff5e6c; box-shadow: none; }

      .orbit:nth-child(1) { animation: rotate1 2s linear infinite; }
      .orbit:nth-child(2) { animation: rotate2 2s linear infinite; }
      .orbit:nth-child(3) { animation: rotate3 2s linear infinite; }

      @keyframes rotate1 {
        0% { transform: rotateZ(0deg) rotateX(65deg) rotateY(0deg); }
        100% { transform: rotateZ(360deg) rotateX(65deg) rotateY(0deg); }
      }
      @keyframes rotate2 {
        0% { transform: rotateZ(0deg) rotateX(65deg) rotateY(60deg); }
        100% { transform: rotateZ(360deg) rotateX(65deg) rotateY(60deg); }
      }
      @keyframes rotate3 {
        0% { transform: rotateZ(0deg) rotateX(65deg) rotateY(-60deg); }
        100% { transform: rotateZ(360deg) rotateX(65deg) rotateY(-60deg); }
      }
      @keyframes pulseNucleus {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.15); opacity: 0.9; }
      }

      .preloader-text {
        font-family: 'system-ui', sans-serif;
        font-weight: 800;
        font-size: 1.75rem;
        letter-spacing: -0.05em;
        color: white;
        opacity: 0;
        animation: fadeInText 1s ease forwards 0.5s; 
      }
      html:not(.dark) .preloader-text { color: #1c1917; }

      @keyframes fadeInText { to { opacity: 1; } }

      body, header, nav, footer, div, span, p, h1, h2, h3, h4, h5, h6, a, button {
        transition-property: background-color, border-color, color, fill, stroke;
        transition-timing-function: ease-in-out;
        transition-duration: 300ms; 
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }
      
      ::view-transition-new(root) {
        z-index: 999;
      }
      
      ::view-transition-old(root) {
        z-index: 1;
      }
      
      .is-transitioning * {
        transition: none !important;
      }

      h1, h2, h3, h4, h5, h6 { letter-spacing: -0.025em; }
      
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background-color: rgba(156, 163, 175, 0.3); 
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover { background-color: rgba(156, 163, 175, 0.6); }
      .dark ::-webkit-scrollbar-thumb { background-color: rgba(75, 85, 99, 0.4); }
      .dark ::-webkit-scrollbar-thumb:hover { background-color: rgba(75, 85, 99, 0.7); }
    </style>
  </head>
  
  <body class="bg-background-light text-text-light dark:bg-background-dark dark:text-text-dark font-sans antialiased selection:bg-primary-light/30 selection:text-primary-light dark:selection:text-primary-dark flex flex-col min-h-screen transition-colors duration-300">
    
    <div id="preloader">
      <div class="atom-container">
        <div class="orbit"></div>
        <div class="orbit"></div>
        <div class="orbit"></div>
        <div class="nucleus"></div>
      </div>
      <div class="preloader-text">
        UPSILON<span class="text-primary-dark">.HUB</span>
      </div>
    </div>
    
    <script is:inline>
      if (sessionStorage.getItem('introShown')) {
        const p = document.getElementById('preloader');
        if (p) p.style.display = 'none';
      }
    </script>

    <div class="fixed top-0 left-0 w-full h-1 z-[60] pointer-events-none bg-transparent">
      <div id="progress-bar" class="h-full bg-primary-light dark:bg-primary-dark origin-left scale-x-0 transition-transform duration-100 ease-out"></div>
    </div>

    <header id="main-header" class="sticky top-0 z-50 bg-background-light dark:bg-background-dark border-b-[3px] border-primary-light/20 dark:border-primary-dark/20 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]">
      
      <!-- TOP ROW: Logo and Utilities -->
      <div class="max-w-[1600px] mx-auto px-4 sm:px-8 h-20 flex items-center justify-between">
        
        <!-- Mobile Menu Button (Left) -->
        <button id="mobile-menu-btn" class="xl:hidden p-2 text-text-light dark:text-text-dark">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
        
        <!-- Center Logo (Absolute on mobile, static on xl) -->
        <a href="/" class="absolute left-1/2 -translate-x-1/2 xl:static xl:transform-none group flex items-center gap-2">
          <span class="text-3xl font-black tracking-tighter text-text-light dark:text-text-dark">
            UPSILON<span class="text-primary-light dark:text-primary-dark">.HUB</span>
          </span>
        </a>

        <!-- Right Side (About & Theme Toggle) -->
        <div class="flex items-center gap-6">
          <a href="/about" class="hidden xl:block text-[13px] font-bold uppercase tracking-[0.15em] text-text-light dark:text-text-dark hover:text-primary-light dark:hover:text-primary-dark transition-colors">About</a>
          
          <button id="theme-toggle-btn" class="p-2 rounded focus:outline-none flex items-center justify-center text-text-light dark:text-text-dark hover:text-primary-light dark:hover:text-primary-dark transition-colors">
            <svg id="theme-toggle-light-icon" class="hidden w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
            <svg id="theme-toggle-dark-icon" class="hidden w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
          </button>
        </div>
      </div>

      <!-- BOTTOM ROW: Scrolling Categories (Desktop Only) -->
      <div class="hidden xl:block w-full border-t border-gray-200 dark:border-gray-800">
        <div class="max-w-[1600px] mx-auto px-8 overflow-x-auto hide-scrollbar">
          <nav class="flex items-center h-14 gap-8">
            <a href="/" class="text-[13px] font-bold uppercase tracking-[0.15em] text-primary-light dark:text-primary-dark whitespace-nowrap flex-shrink-0 hover:underline">
              All Topics
            </a>

            <a href="/saved" class="flex items-center gap-2 text-[13px] font-bold uppercase tracking-[0.15em] text-text-light dark:text-text-dark whitespace-nowrap flex-shrink-0 hover:text-primary-light dark:hover:text-primary-dark transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
              Bookmarks
            </a>

            <div class="h-4 w-px bg-gray-300 dark:bg-gray-700 flex-shrink-0"></div>

            {uniqueCategories.map((category: any) => (
              <a 
                href={`/category/${category.toLowerCase().replace(/\s+/g, '-')}`} 
                class="text-[13px] font-bold uppercase tracking-[0.15em] text-text-light dark:text-text-dark hover:text-primary-light dark:hover:text-primary-dark transition-colors whitespace-nowrap flex-shrink-0"
              >
                  {category}
              </a>
            ))}
          </nav>
        </div>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden xl:hidden border-t-4 border-primary-light/10 dark:border-primary-dark/10 bg-background-light dark:bg-background-dark absolute w-full left-0 top-20 flex-col py-8 px-8 shadow-2xl z-40 gap-6">
        <a href="/" class="text-[14px] font-bold uppercase tracking-[0.2em] text-text-light dark:text-text-dark hover:text-primary-light">All Topics</a>
        <a href="/saved" class="text-[14px] font-bold uppercase tracking-[0.2em] text-text-light dark:text-text-dark hover:text-primary-light">Bookmarks</a>
        <a href="/about" class="text-[14px] font-bold uppercase tracking-[0.2em] text-text-light dark:text-text-dark hover:text-primary-light">About</a>
        <hr class="border-gray-200 dark:border-gray-800 my-2" />
        {uniqueCategories.map((cat: any) => (
          <a href={`/category/${cat.toLowerCase().replace(/\s+/g, '-')}`} class="text-[14px] font-bold uppercase tracking-[0.2em] text-text-light dark:text-text-dark hover:text-primary-light">{cat}</a>
        ))}
      </div>
    </header>

    <main class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-6 pb-20 flex-grow w-full">
      <slot />
    </main>

    <footer class="border-t border-gray-200 dark:border-gray-800 mt-20 py-10 text-center">
      <p class="text-gray-500 dark:text-gray-600 text-sm font-medium">
        &copy; {new Date().getFullYear()} Upsilon Hub. The Frontier of Physics.
      </p>
    </footer>

    <button id="scrollToTop" class="fixed bottom-12 right-6 md:bottom-10 md:right-10 p-4 rounded-xl bg-primary-light dark:bg-primary-dark text-white hover:bg-opacity-90 opacity-0 invisible translate-y-10 transition-all duration-300 z-[9999] shadow-2xl">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
    </button>

    <script>
      const initPreloader = () => {
        const preloader = document.getElementById('preloader');
        if (!preloader) return;
        
        if (sessionStorage.getItem('introShown')) {
          preloader.style.display = 'none';
          return;
        }
        
        window.addEventListener('load', () => {
          setTimeout(() => {
            preloader.classList.add('preloader-hidden');
            sessionStorage.setItem('introShown', 'true');
          }, 2000); 
        });
      };

      initPreloader();
      document.addEventListener('astro:page-load', () => {
      });

      const themeToggleBtn = document.getElementById('theme-toggle-btn');
      const lightIcon = document.getElementById('theme-toggle-light-icon');
      const darkIcon = document.getElementById('theme-toggle-dark-icon');
      const html = document.documentElement;

      if (html.classList.contains('dark')) lightIcon.classList.remove('hidden');
      else darkIcon.classList.remove('hidden');

      themeToggleBtn.addEventListener('click', (event) => {
        
        if (!document.startViewTransition) {
          performToggle();
          return;
        }

        document.documentElement.classList.add('is-transitioning');

        const transition = document.startViewTransition(() => {
          performToggle();
        });

        transition.ready.then(() => {
          const x = event.clientX;
          const y = event.clientY;
          const endRadius = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));

          document.documentElement.animate(
            { clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${endRadius}px at ${x}px ${y}px)`] },
            { duration: 500, easing: "ease-in", pseudoElement: "::view-transition-new(root)" }
          );
        });

        transition.finished.then(() => {
          document.documentElement.classList.remove('is-transitioning');
        });
      });

      function performToggle() {
        lightIcon.classList.toggle('hidden');
        darkIcon.classList.toggle('hidden');
        const isDark = html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }

      const header = document.getElementById('main-header');
      const progressBar = document.getElementById('progress-bar');
      const scrollBtn = document.getElementById('scrollToTop');
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          mobileMenu.classList.toggle('flex');
        });
      }

      let lastScrollY = window.scrollY;

      window.addEventListener('scroll', () => {
        const currentScrollY = window.scrollY;
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const scrolled = (winScroll / height);
        if (progressBar) progressBar.style.transform = `scaleX(${scrolled})`;

        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          header.classList.add('-translate-y-full');
        } else {
          header.classList.remove('-translate-y-full');
        }
        
        if (currentScrollY > 400) {
          scrollBtn.classList.remove('opacity-0', 'invisible', 'translate-y-10');
        } else {
          scrollBtn.classList.add('opacity-0', 'invisible', 'translate-y-10');
        }
        lastScrollY = currentScrollY;
      });

      scrollBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    </script>
  </body>
</html>