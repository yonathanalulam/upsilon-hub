---
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import FadeIn from '../components/FadeIn.jsx';
import newsData from '../data/news.json';

const safeNews = newsData || [];
---

<Layout title="Upsilon Hub">
  
  <div class="flex flex-col gap-12 pb-20">
    
    <header class="mb-8 mt-8 border-b border-gray-200 dark:border-gray-800 pb-6">
      <h1 class="text-3xl md:text-4xl font-bold text-text-light dark:text-text-dark mb-4">
        Latest Research
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        Reports from leading research institutions.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {safeNews.map((item, index) => (
  
        <FadeIn client:load delay={(index % 6) * 0.05}>
          <div class="h-full">
            <NewsCard 
              title={item.title}
              category={item.category}
              image={item.image}
              summary={item.summary}
              url={item.link}
              sourceName={item.sourceName} 
            />
          </div>
        </FadeIn>
      ))}
    </div>

  </div>

</Layout>