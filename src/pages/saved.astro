---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Saved Articles | Upsilon Hub" description="Your personal collection of physics reports and scientific breakthroughs saved from Upsilon Hub.">
  
  <header class="mb-6 mt-4 border-b border-gray-200 dark:border-gray-800 pb-6">
    <div class="flex items-center gap-4 mb-2">
      <div class="text-primary-light dark:text-primary-dark">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
      </div>
      <h1 class="text-3xl font-bold text-text-light dark:text-text-dark">
        Saved Articles
      </h1>
    </div>
    <p class="text-lg text-gray-600 dark:text-gray-400">
      Your personal collection of physics reports.
    </p>
  </header>

  <div id="savedGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    </div>

  <div id="emptyState" class="hidden flex flex-col items-center justify-center py-20 text-center">
    <div class="mb-6">
      <svg class="w-10 h-10 text-gray-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
    </div>
    <h2 class="text-2xl font-bold text-text-light dark:text-text-dark mb-2">No saved articles yet</h2>
    <p class="text-gray-500 mb-8 max-w-md mx-auto">Click the bookmark icon on any article to add it to your reading list.</p>
    <a href="/" class="px-4 py-2 bg-primary-light hover:opacity-90 text-white font-medium rounded transition-opacity">
      Browse News
    </a>
  </div>

</Layout>

<script is:inline>
  const savedGrid = document.getElementById('savedGrid');
  const emptyState = document.getElementById('emptyState');
  
  const savedArticles = JSON.parse(localStorage.getItem('ups_saved_articles') || '[]');

  if (savedArticles.length === 0) {
    emptyState.classList.remove('hidden');
  } else {

    savedArticles.forEach((item, index) => {
      const delay = Math.min(index * 50, 800);
      
      const cardHTML = `
        <div class="group relative flex flex-col h-full bg-transparent dark:bg-transparent transition-all duration-300 border border-gray-200 dark:border-gray-800 rounded-lg" style="animation-delay: ${delay}ms" data-url="${item.url}">
          
          <div class="h-48 overflow-hidden relative">
             <div class="absolute top-2 left-2 z-20">
              <span class="inline-block px-2 py-1 text-xs font-medium text-white bg-primary-light dark:bg-primary-dark rounded hover:opacity-90 transition-opacity">
                ${item.category}
              </span>
            </div>
            
            <button onclick="window.removeArticle('${item.url}', this)" class="absolute top-2 right-2 z-30 p-2 rounded bg-surface-light dark:bg-surface-dark border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" title="Remove">
               <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <a href="${item.url}" target="_blank" class="block h-full w-full">
              <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover" loading="lazy" />
            </a>
          </div>

          <div class="p-4 flex flex-col flex-grow">
            <a href="${item.url}" target="_blank" class="block">
              <h3 class="text-lg font-bold text-text-light dark:text-text-dark mb-2 leading-snug group-hover:text-primary-light dark:group-hover:text-primary-dark transition-colors">
                ${item.title}
              </h3>
            </a>
            <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-3 leading-relaxed mb-4 flex-grow">
              ${item.summary}
            </p>
            <div class="border-t border-gray-200 dark:border-gray-800 pt-3 mt-auto flex justify-between items-center">
                <span class="text-sm font-medium text-gray-600 dark:text-gray-400">
                  ${item.sourceName || 'Source'}
                </span>
                <a href="${item.url}" target="_blank" class="text-primary-light dark:text-primary-dark font-medium text-sm hover:underline">Read</a>
            </div>
          </div>
        </div>
      `;
      savedGrid.innerHTML += cardHTML;
    });
  }

  window.removeArticle = (url, btnElement) => {
    const current = JSON.parse(localStorage.getItem('ups_saved_articles') || '[]');
    const updated = current.filter(i => i.url !== url);
    localStorage.setItem('ups_saved_articles', JSON.stringify(updated));

    const card = btnElement.closest('[data-url]');
    if (card) {
        card.style.opacity = '0';
        card.style.transform = 'scale(0.9)';
        setTimeout(() => {
            card.remove();
            if (updated.length === 0) {
                document.getElementById('emptyState').classList.remove('hidden');
            }
        }, 300);
    }
  };
</script>