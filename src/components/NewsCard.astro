---
const { title, category, image, summary, url, sourceName, slug } = Astro.props;
const categorySlug = category.toLowerCase().replace(/\s+/g, '-');
---

<div 
  class="group relative flex flex-col h-full bg-transparent dark:bg-transparent transition-all duration-300 border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden"
  data-title={title.toLowerCase()}
  data-category={category.toLowerCase()}
  data-source={sourceName?.toLowerCase() || ''}
>
  
  <div class="h-48 overflow-hidden relative">
    
    <div class="absolute top-2 left-2 z-20">
      <a href={`/category/${categorySlug}`} class="inline-block px-2 py-1 text-xs font-medium text-white bg-primary-light dark:bg-primary-dark rounded hover:opacity-90 transition-opacity">
        {category}
      </a>
    </div>

    <button 
      class="bookmark-btn absolute top-2 right-2 z-30 p-2 rounded bg-surface-light dark:bg-surface-dark hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors group/btn border border-gray-200 dark:border-gray-700"
      data-url={url}
      data-slug={slug}
      data-title={title}
      data-image={image}
      data-category={category}
      data-summary={summary}
      data-source={sourceName}
      aria-label="Save article"
    >
      <svg class="bookmark-icon-empty w-5 h-5 text-text-light dark:text-text-dark group-hover/btn:text-primary-light dark:group-hover/btn:text-primary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
      <svg class="bookmark-icon-filled hidden w-5 h-5 text-primary-light dark:text-primary-dark" fill="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
    </button>

    <a href={`/article/${slug}`} class="block h-full w-full">
      <img 
        src={image} 
        alt={title} 
        loading="lazy"
        class="w-full h-full object-cover"
        onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=800&q=80';" 
      />
    </a>
  </div>

  <div class="p-4 flex flex-col flex-grow">
    <a href={`/article/${slug}`} class="block">
      <h3 class="text-lg font-bold text-text-light dark:text-text-dark mb-2 leading-snug group-hover:text-primary-light dark:group-hover:text-primary-dark transition-colors">
        {title}
      </h3>
    </a>

    <p class="text-gray-600 dark:text-gray-400 text-sm line-clamp-3 leading-relaxed mb-4 flex-grow">
      {summary}
    </p>
    
    <div class="border-t border-gray-200 dark:border-gray-800 pt-3 mt-auto flex justify-between items-center">
        <span class="text-sm font-medium text-gray-600 dark:text-gray-400">
          {sourceName || "Science Daily"}
        </span>
        
        <a href={`/article/${slug}`} class="inline-flex items-center text-primary-light dark:text-primary-dark font-medium text-sm hover:underline">
        Read
        </a>
    </div>
  </div>
</div>

<script>
  function initBookmarks() {
    const buttons = document.querySelectorAll('.bookmark-btn');
    
    buttons.forEach(btn => {
      if (!(btn instanceof HTMLElement)) return;

      const url = btn.dataset.url;
      const emptyIcon = btn.querySelector('.bookmark-icon-empty');
      const filledIcon = btn.querySelector('.bookmark-icon-filled');

      const saved = JSON.parse(localStorage.getItem('ups_saved_articles') || '[]');
      const isSaved = saved.some(item => item.url === url);

      if (isSaved) {
        emptyIcon.classList.add('hidden');
        filledIcon.classList.remove('hidden');
      } else {
        emptyIcon.classList.remove('hidden');
        filledIcon.classList.add('hidden');
      }

      btn.addEventListener('click', (e) => {
        e.preventDefault(); 
        
        const currentSaved = JSON.parse(localStorage.getItem('ups_saved_articles') || '[]');
        const existingIndex = currentSaved.findIndex(item => item.url === url);

        if (existingIndex > -1) {
          currentSaved.splice(existingIndex, 1);
          emptyIcon.classList.remove('hidden');
          filledIcon.classList.add('hidden');
        } else {
          const articleData = {
            url: btn.dataset.url,
            slug: btn.dataset.slug,
            title: btn.dataset.title,
            image: btn.dataset.image,
            category: btn.dataset.category,
            summary: btn.dataset.summary,
            sourceName: btn.dataset.source
          };
          currentSaved.push(articleData);
          emptyIcon.classList.add('hidden');
          filledIcon.classList.remove('hidden');
        }

        localStorage.setItem('ups_saved_articles', JSON.stringify(currentSaved));
      });
    });
  }

  initBookmarks();
  document.addEventListener('astro:page-load', initBookmarks);
</script>
